# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://algo11:algo1122@ac-ia918tm-shard-00-00.qshvlll.mongodb.net:27017,ac-ia918tm-shard-00-01.qshvlll.mongodb.net:27017,ac-ia918tm-shard-00-02.qshvlll.mongodb.net:27017/?ssl=true&replicaSet=atlas-oerudg-shard-0&authSource=admin&appName=Cluster0

# For MongoDB Atlas use:
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/algotrade

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d

# ─── Encryption (AES-256 for broker tokens) ───────────────────────────────────
ENCRYPTION_KEY=replace_with_32_char_secret_key_here

# ─── Angel One (Admin market data account) ────────────────────────────────────
ANGELONE_CLIENT_ID=your_client_id
ANGELONE_API_KEY=your_api_key
ANGELONE_TOTP_SECRET=your_totp_secret
ANGELONE_PIN=your_mpin

# ─── TradingView Webhook ──────────────────────────────────────────────────────
WEBHOOK_SECRET=replace_with_webhook_secret
